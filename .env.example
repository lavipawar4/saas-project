# Environment Variables — copy this file to .env.local and fill in real values.
# Variables marked [REQUIRED] must be set. [OPTIONAL] enable specific features.

# ─────────────────────────────────────────────
# SUPABASE — [REQUIRED]
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─────────────────────────────────────────────
# ANTHROPIC (Claude AI) — [REQUIRED]
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# GOOGLE BUSINESS PROFILE — [REQUIRED]
# OAuth app: https://console.cloud.google.com
# Enable: Google Business Profile API
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ─────────────────────────────────────────────
# STRIPE — [REQUIRED for billing]
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_...
STRIPE_AGENCY_ANNUAL_PRICE_ID=price_...

# ─────────────────────────────────────────────
# RESEND (email alerts) — [OPTIONAL]
# https://resend.com — free tier: 100 emails/day
# Verify sender domain before using in production.
# Without this, negative-review email alerts are silently skipped.
# ─────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ─────────────────────────────────────────────
# UPSTASH REDIS (rate limiting) — [OPTIONAL]
# https://upstash.com → Create Redis DB → REST API tab
# Without these, all rate limits are disabled (always allows).
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─────────────────────────────────────────────
# APP CONFIG — [REQUIRED]
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron + dev test routes secret — generate: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
